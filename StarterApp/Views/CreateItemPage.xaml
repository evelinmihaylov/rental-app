<?xml version="1.0" encoding="utf-8" ?>
<ContentPage x:Class="StarterApp.Views.CreateItemPage"
             xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             Title="{Binding Title}">

    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="15">

            <!-- Error Message -->
            <Border BackgroundColor="{AppThemeBinding Light=#FFEBEE, Dark=#1B0000}"
                    Stroke="{AppThemeBinding Light=#F44336, Dark=#EF5350}"
                    StrokeThickness="1"
                    Padding="15"
                    IsVisible="{Binding HasError}">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="8" />
                </Border.StrokeShape>
                <Label Text="{Binding ErrorMessage}"
                       TextColor="{AppThemeBinding Light=#D32F2F, Dark=#EF5350}"
                       FontSize="14" />
            </Border>

            <!-- Title -->
            <Label Text="Title" FontAttributes="Bold" />
            <Border Stroke="{AppThemeBinding Light={StaticResource Gray300}, Dark={StaticResource Gray600}}"
                    StrokeThickness="1"
                    BackgroundColor="{AppThemeBinding Light={StaticResource White}, Dark={StaticResource Gray900}}">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="8" />
                </Border.StrokeShape>
                <Entry Text="{Binding TitleText}"
                       Placeholder="Enter item title"
                       Margin="10" />
            </Border>

            <!-- Category Picker -->
            <Label Text="Category" FontAttributes="Bold" />
            <Border Stroke="{AppThemeBinding Light={StaticResource Gray300}, Dark={StaticResource Gray600}}"
                    StrokeThickness="1"
                    BackgroundColor="{AppThemeBinding Light={StaticResource White}, Dark={StaticResource Gray900}}">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="8" />
                </Border.StrokeShape>
                <Picker ItemsSource="{Binding Categories}"
                        ItemDisplayBinding="{Binding Name}"
                        SelectedItem="{Binding SelectedCategory}"
                        Title="Select category"
                        Margin="10" />
            </Border>

            <!-- Description -->
            <Label Text="Description" FontAttributes="Bold" />
            <Border Stroke="{AppThemeBinding Light={StaticResource Gray300}, Dark={StaticResource Gray600}}"
                    StrokeThickness="1"
                    BackgroundColor="{AppThemeBinding Light={StaticResource White}, Dark={StaticResource Gray900}}">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="8" />
                </Border.StrokeShape>
                <Editor Text="{Binding Description}"
                        Placeholder="Enter item description"
                        HeightRequest="200"
                        Margin="10"
                        AutoSize="TextChanges" />
            </Border>

            <!-- Daily Rate -->
            <Label Text="Daily Rate" FontAttributes="Bold" />
            <Border Stroke="{AppThemeBinding Light={StaticResource Gray300}, Dark={StaticResource Gray600}}"
                    StrokeThickness="1"
                    BackgroundColor="{AppThemeBinding Light={StaticResource White}, Dark={StaticResource Gray900}}">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="8" />
                </Border.StrokeShape>
                <Entry Text="{Binding DailyRate}"
                       Keyboard="Numeric"
                       Placeholder="Enter daily rate"
                       Margin="10" />
            </Border>

            <!-- Latitude -->
            <Label Text="Latitude" FontAttributes="Bold" />
            <Border Stroke="{AppThemeBinding Light={StaticResource Gray300}, Dark={StaticResource Gray600}}"
                    StrokeThickness="1"
                    BackgroundColor="{AppThemeBinding Light={StaticResource White}, Dark={StaticResource Gray900}}">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="8" />
                </Border.StrokeShape>
                <Entry Text="{Binding Latitude}"
                       Keyboard="Numeric"
                       Placeholder="Enter latitude"
                       Margin="10" />
            </Border>

            <!-- Longitude -->
            <Label Text="Longitude" FontAttributes="Bold" />
            <Border Stroke="{AppThemeBinding Light={StaticResource Gray300}, Dark={StaticResource Gray600}}"
                    StrokeThickness="1"
                    BackgroundColor="{AppThemeBinding Light={StaticResource White}, Dark={StaticResource Gray900}}">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="8" />
                </Border.StrokeShape>
                <Entry Text="{Binding Longitude}"
                       Keyboard="Numeric"
                       Placeholder="Enter longitude"
                       Margin="10" />
            </Border>

            <!-- Action Buttons -->
            <Grid ColumnDefinitions="*,*" ColumnSpacing="10" Margin="0,20,0,0">

                <Button Grid.Column="0"
                        Text="{Binding SaveButtonText}"
                        Command="{Binding SaveCommand}"
                        BackgroundColor="{AppThemeBinding Light={StaticResource Primary}, Dark={StaticResource PrimaryDark}}"
                        TextColor="White"
                        HeightRequest="50"
                        CornerRadius="8"
                        IsEnabled="{Binding IsNotBusy}" />

                <Button Grid.Column="1"
                        Text="Cancel"
                        Command="{Binding CancelCommand}"
                        BackgroundColor="Transparent"
                        TextColor="{AppThemeBinding Light={StaticResource Gray600}, Dark={StaticResource Gray400}}"
                        BorderColor="{AppThemeBinding Light={StaticResource Gray300}, Dark={StaticResource Gray600}}"
                        BorderWidth="1"
                        HeightRequest="50"
                        CornerRadius="8" />
            </Grid>

            <!-- Loading Indicator -->
            <ActivityIndicator IsVisible="{Binding IsBusy}"
                               IsRunning="{Binding IsBusy}"
                               Color="{AppThemeBinding Light={StaticResource Primary}, Dark={StaticResource PrimaryDark}}"
                               Margin="0,20,0,0" />

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>