<?xml version="1.0" encoding="UTF-8" ?>
<Shell x:Class="StarterApp.AppShell"
       xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
       xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
       xmlns:views="clr-namespace:StarterApp.Views"
       Shell.FlyoutBehavior="Flyout">

    <FlyoutItem Title="All Items" Route="items">   
         <ShellContent ContentTemplate="{DataTemplate views:ItemsListPage}" />
    </FlyoutItem>

    <FlyoutItem Title="Find Near Me" Route="nearbyitems">
        <ShellContent ContentTemplate="{DataTemplate views:NearbyItemsPage}" />
    </FlyoutItem>

    <FlyoutItem Title="Rentals" Route="rentals">
        <ShellContent ContentTemplate="{DataTemplate views:RentalsPage}" />
    </FlyoutItem>
    
    <MenuItem Text="Profile"
              Command="{Binding NavigateToProfileCommand}" />

    <MenuItem Text="Logout"
              Command="{Binding LogoutCommand}" />
</Shell>